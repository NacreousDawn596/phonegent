# PhoneGent backend configuration
# Copy this to .env and adjust values

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_VISION_MODEL=llava
OLLAMA_TIMEOUT=120

HOST=0.0.0.0
PORT=8000

DB_PATH=./phonegent.db
MEDIA_DIR=./media

# Change this to a random secret — the app sends it in X-API-Secret header
API_SECRET=change_me_to_something_random
